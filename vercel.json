{
  "version": 2,
  "builds": [
    { "src": "api/get_card.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "sounds/**", "use": "@vercel/static" },
    { "src": "cvm.jpeg", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/get_card", "dest": "/api/get_card.py" },
    { "handle": "filesystem" }
  ]
}
